PROMPT VAGO CALCULADORA

"Aqui está um código em Python simples e interativo para somar notas. Ele também calcula a média, que costuma ser bem útil nesse tipo de situação.

Python
def calcular_soma_notas():
    notas = []
    
    # Pergunta ao usuário quantas notas serão inseridas
    try:
        quantidade = int(input("Quantas notas você deseja somar? "))
    except ValueError:
        print("Por favor, digite um número inteiro válido.")
        return

    # Coleta cada uma das notas
    for i in range(quantidade):
        while True:
            try:
                nota = float(input(f"Digite a {i+1}ª nota: "))
                notas.append(nota)
                break
            except ValueError:
                print("Valor inválido. Por favor, digite um número (ex: 8.5).")

    # Calcula a soma e a média
    soma = sum(notas)
    media = soma / quantidade if quantidade > 0 else 0

    # Exibe o resultado
    print("\n--- Resultado ---")
    print(f"Notas inseridas: {notas}")
    print(f"Soma total: {soma:.2f}")
    print(f"Média: {media:.2f}")

# Executa a função
calcular_soma_notas()
