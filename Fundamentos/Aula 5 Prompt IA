Python
# Importa o módulo sys para podermos encerrar a execução de forma elegante, caso necessário.
import sys

# Define a função principal com anotação de tipo informando que ela não retorna nada (None).
def iniciar_calculadora_notas() -> None:
    # Inicializa a variável que armazenará a soma total, tipada estritamente como um número decimal (float).
    soma_total: float = 0.0
    
    # Exibe uma mensagem de boas-vindas e instruções iniciais para o usuário no console.
    print("=== Calculadora de Soma de Notas ===")
    
    # Exibe a instrução de como interromper o programa, garantindo uma boa experiência de usuário (UX).
    print("Instrução: Digite 'sair' a qualquer momento para ver o resultado final.")
    
    # Inicia um loop infinito que manterá o programa rodando até que o usuário decida parar.
    while True:
        # Solicita a entrada do usuário, remove espaços em branco extras (strip) e converte para minúsculas (lower).
        entrada_usuario: str = input("\nDigite a nota do aluno: ").strip().lower()
        
        # Verifica se o valor inserido corresponde ao comando de parada pré-estabelecido ('sair').
        if entrada_usuario == 'sair':
            # Se for o comando de parada, o comando 'break' interrompe a execução do loop imediatamente.
            break
            
        # Inicia um bloco 'try' para lidar com possíveis erros de conversão de tipo (tratamento de exceções).
        try:
            # Tenta converter o texto digitado pelo usuário em um número decimal (float).
            nota_convertida: float = float(entrada_usuario)
            
            # Realiza uma validação de regra de negócio simples: verifica se a nota inserida é negativa.
            if nota_convertida < 0:
                # Se for negativa, exibe um alerta, pois notas negativas geralmente indicam um erro de digitação.
                print("Aviso: Você inseriu uma nota negativa. Ela será computada, mas verifique se está correto.")
                
            # Adiciona o valor da nota convertida à nossa variável acumuladora (soma_total).
            soma_total += nota_convertida
            
            # Dá um feedback visual rápido para o usuário saber que a nota foi registrada com sucesso.
            print(f"Sucesso! Nota {nota_convertida:.2f} adicionada.")
            
        # Caso a conversão para float falhe (ex: o usuário digitou "A" ou "dez"), o ValueError é capturado.
        except ValueError:
            # Informa ao usuário de forma amigável que o valor inserido é inválido, sem quebrar o programa.
            print("Erro de validação: Por favor, digite apenas números (ex: 8.5 ou 10).")

    # Após o loop ser encerrado pelo comando 'break', uma linha em branco é impressa para organização visual.
    print("\n------------------------------------")
    
    # Imprime o resultado final da soma formatando o número para exibir apenas duas casas decimais (.2f).
    print(f"RESULTADO FINAL: A soma de todas as notas é {soma_total:.2f}")

# Bloco condicional padrão em Python para garantir que o código só rode se o arquivo for executado diretamente.
if __name__ == "__main__":
    # Chama a função principal pela primeira vez, iniciando o fluxo do nosso software.
    iniciar_calculadora_notas()
Por que essa abordagem?
Mesmo em um teste simples, um perfil sênior precisa mostrar que pensa na robustez do software. Adicionar tratamento de exceções (try/except) evita crashes, sanitizar a entrada do usuário (.strip().lower()) evita erros bobos de digitação, e usar type hints (-> None, : float) facilita a vida de outros desenvolvedores que forem ler o código no futuro.
